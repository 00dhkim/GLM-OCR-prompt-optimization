OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5-nano

# vLLM or other OpenAI-compatible OCR server
OLLAMA_BASE_URL=http://localhost:8000/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=GLM-OCR

# Arize AX / Phoenix Cloud
PHOENIX_API_KEY=your-arize-ax-api-key
# Leave empty for Arize AX unless you have a custom OTLP collector endpoint.
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_PROJECT_NAME=glm-ocr-prompt-optimization
# Optional. Only set this if you have a confirmed Phoenix app API base URL.
PHOENIX_BASE_URL=
# Optional when your AX workspace requires a space id
PHOENIX_CLIENT_HEADERS=api_key=your-arize-ax-api-key,space_id=your-space-id
